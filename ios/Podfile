# Uncomment the next line to define a global platform for your project
platform :ios, '13.0'
install! 'cocoapods', :deterministic_uuids => false

# React Native 最小 iOS 版本
MIN_IOS_VERSION = '13.0'

target 'LxMusicMobile' do
  config = use_native_modules!

  # React Native 核心
  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # 保留的官方支持 iOS 的依赖
  # react-native-fs（官方支持 iOS）
  # react-native-async-storage（官方支持 iOS）
  # react-native-clipboard（官方支持 iOS）
  # react-native-community/slider（官方支持 iOS）
  # react-native-quick-base64（官方支持 iOS）
  # react-native-quick-md5（官方支持 iOS）
  # react-native-vector-icons（官方支持 iOS）
  # react-native-navigation（官方支持 iOS）
  # react-native-pager-view（官方支持 iOS）
  # react-native-exception-handler（官方支持 iOS）

  # iOS 专属依赖
  # CarPlay 框架（系统框架，无需 Pod）
  # AVKit / AVFoundation（系统框架，无需 Pod）

  post_install do |installer|
    react_native_post_install(installer)
    # 确保 iOS 最低版本
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = MIN_IOS_VERSION
      end
    end
  end
end

target 'LxMusicMobileTests' do
  inherit! :complete
  # Pods for testing
end
